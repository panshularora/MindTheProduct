# Product Council AI - Environment Variables

# Option 1: Groq API Key (recommended - free tier available)
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Option 2: Anthropic API Key (fallback)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Note: GROQ_API_KEY takes priority if both are set.
# At least one key must be configured for the app to work.
